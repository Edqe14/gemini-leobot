generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid()) @map("_id")
  email         String    @unique
  name          String?
  image         String?
  emailVerified Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  projects      Project[]
  sessions      Session[]
  accounts      Account[]
}

model Session {
  id        String   @id @default(cuid()) @map("_id")
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                    String    @id @default(cuid()) @map("_id")
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
}

model Verification {
  id         String   @id @default(cuid()) @map("_id")
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([identifier, value])
}

model Project {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  story           Story?
  characterNodes  CharacterNode[]
  styleNodes      StyleNode[]
  storyboardNodes StoryboardNode[]
}

model Story {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  projectId        String   @unique @db.ObjectId
  title            String
  sourceDocUrl     String?
  markdown         String
  pendingRewriteInstruction String?
  pendingRewriteSelectionText String?
  pendingRewriteSelectionStart Int?
  pendingRewriteSelectionEnd Int?
  pendingRewriteReplacementText String?
  pendingRewriteMarkdown String?
  pendingRewriteSummary String?
  pendingRewriteSource String?
  pendingRewriteToolCallId String?
  pendingRewriteCreatedAt DateTime?
  pendingRewriteUpdatedAt DateTime?
  positionX        Float?
  positionY        Float?
  importedAt       DateTime @default(now())
  backgroundPrompt String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  revisions StoryRevision[]
}

model StoryRevision {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  storyId        String   @db.ObjectId
  projectId      String   @db.ObjectId
  instruction    String
  selectionText  String
  selectionStart Int
  selectionEnd   Int
  summary        String
  previousMarkdown String
  nextMarkdown   String
  source         String?
  acceptedAt     DateTime @default(now())
  createdAt      DateTime @default(now())

  story Story @relation(fields: [storyId], references: [id], onDelete: Cascade)

  @@index([storyId, acceptedAt(sort: Desc)])
  @@index([projectId, acceptedAt(sort: Desc)])
}

model CharacterNode {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  projectId         String   @db.ObjectId
  name              String
  briefMarkdown     String
  profileJson       String?
  inspirationPrompt String?
  inspirationUrls   String[]
  positionX         Float?
  positionY         Float?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model StyleNode {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  projectId   String   @unique @db.ObjectId
  name        String
  description String
  writingStyle String
  characterStyle String
  artStyle String
  storytellingPacing String
  extrasJson   String?
  positionX   Float?
  positionY   Float?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model StoryboardNode {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  projectId  String   @db.ObjectId
  title      String
  shotsJson  String
  positionX  Float?
  positionY  Float?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}
