# App URLs
APP_BASE_URL=http://localhost:5173
API_BASE_URL=http://localhost:8787
VITE_AUTH_BASE_URL=http://localhost:5173/api/auth
PORT=8787
NODE_ENV=development

# Database
DATABASE_URL=mongodb+srv://<username>:<password>@<cluster>/<db>?retryWrites=true&w=majority

# Better Auth
BETTER_AUTH_SECRET=replace-with-a-long-random-secret
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret

# Gemini via Google GenAI SDK
# Option A (project convention): ai_studio | vertex
GEMINI_PROVIDER=ai_studio
# Option B (Google quickstart convention): True uses Vertex, False uses AI Studio
GOOGLE_GENAI_USE_VERTEXAI=False

# Gemini via Google AI Studio
GEMINI_API_KEY=your-gemini-api-key

# Gemini via Vertex AI (ADC)
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
# Optional for local dev with service account credentials file:
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json

GEMINI_LIVE_MODEL=gemini-live-2.5-flash-preview
GEMINI_CHARACTER_SUBAGENT_MODEL=gemini-2.5-flash

# Debug monitor (server-side)
DEBUG_MONITOR_ENABLED=false
DEBUG_MONITOR_MAX_EVENTS=2000
